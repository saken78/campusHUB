{
  "name": "Bun-campusHub",
  "type": "module",
  "scripts": {
    "start": "tsc --noemit && bun run --watch src/index.ts",
    "sh": "tsc --noemit && bun run --watch src/index.ts",
    "check": "tsc --noEmit",
    "pull": "bunx --bun prisma db pull",
    "push": "bunx --bun prisma db push",
    "generate": "bunx --bun prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.30",
    "hono-rate-limiter": "^0.5.3",
    "prisma": "^7.8.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
